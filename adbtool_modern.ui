 <property name="styleSheet">
 <string notr="true">/* ========== 全局样式 ========== */
QMainWindow {
 background: #1e1e2e;
}

QWidget {
 color: #e0e0e0;
 font-family: 'Microsoft YaHei UI', 'Segoe UI', sans-serif;
 font-size: 9px;
}

/* ========== 功能按钮样式 ========== */
QPushButton {
 background: #2a3a50;
 color: #d0d0d0;
 border: 1px solid #3d5a80;
 border-radius: 4px;
 padding: 4px 8px;
 font-size: 9px;
}
QPushButton:hover {
 background: #3d5a80;
 color: white;
 border: 1px solid #5a9bd5;
}
QPushButton:pressed {
 background: #2a4a70;
}
QPushButton:disabled {
 background: #2a2a3a;
 color: #5a5a6a;
 border: 1px solid #3a3a4a;
}

/* ========== 输入框样式 ========== */
QLineEdit, QTextEdit, QTextBrowser {
 background: #151521;
 color: #98c379;
 border: 1px solid #3d5a80;
 border-radius: 6px;
 padding: 6px 10px;
}
QLineEdit:focus, QTextEdit:focus, QTextBrowser:focus {
 border: 1px solid #5a7ba8;
}

/* ========== 下拉框样式 ========== */
QComboBox {
 background: #2a2a3a;
 color: #e0e0e0;
 border: 1px solid #3d5a80;
 border-radius: 6px;
 padding: 5px 10px;
 min-width: 80px;
}
QComboBox:hover {
 border: 1px solid #5a7ba8;
 background: #353545;
}
QComboBox::drop-down {
 border: none;
 width: 25px;
}
QComboBox::down-arrow {
 image: none;
 border-left: 5px solid transparent;
 border-right: 5px solid transparent;
 border-top: 6px solid #5a7ba8;
}
QComboBox QAbstractItemView {
 background-color: #1e1e2e;
 color: #e0e0e0;
 selection-background-color: #3d5a80;
 border: 1px solid #3d5a80;
}

/* ========== 复选框样式 ========== */
QCheckBox {
 color: #e0e0e0;
 spacing: 8px;
}
QCheckBox::indicator {
 width: 18px;
 height: 18px;
 border-radius: 4px;
 border: 2px solid #3d5a80;
 background: transparent;
}
QCheckBox::indicator:checked {
 background: #3d5a80;
 border: 2px solid #5a7ba8;
}
QCheckBox::indicator:hover {
 border: 2px solid #5a7ba8;
}

/* ========== 标签样式 ========== */
QLabel {
 color: #b0b0c0;
}

/* ========== 分组框样式 ========== */
QGroupBox {
 color: #e0e0e0;
 border: 1px solid #3d5a80;
 border-radius: 8px;
 margin-top: 12px;
 padding: 6px 4px 4px 4px;
 font-weight: bold;
 background: rgba(255, 255, 255, 0.02);
}
QGroupBox::title {
 subcontrol-origin: margin;
 subcontrol-position: top left;
 left: 12px;
 padding: 0 6px;
 color: #5a9bd5;
 background: #1e1e2e;
}

/* ========== 滚动条样式 ========== */
QScrollBar:vertical {
 background: #151521;
 width: 10px;
 border-radius: 5px;
}
QScrollBar::handle:vertical {
 background: #3d5a80;
 border-radius: 5px;
 min-height: 20px;
}
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
 height: 0px;
}
QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
 background: none;
}

QScrollBar:horizontal {
 background: #151521;
 height: 10px;
 border-radius: 5px;
}
QScrollBar::handle:horizontal {
 background: #3d5a80;
 border-radius: 5px;
 min-width: 20px;
}

/* ========== 滚动区域样式 ========== */
QScrollArea {
 border: none;
 background: transparent;
}
QScrollArea > QWidget > QWidget {
 background: transparent;
}

/* ========== 标签窗口样式 ========== */
QTabWidget {
 background: transparent;
}
QTabWidget::pane {
 border: none;
 background: transparent;
}
QTabBar {
 qproperty-visible: false;
 height: 0px;
}
QTabBar::tab {
 height: 0px;
 width: 0px;
 padding: 0px;
 margin: 0px;
}

/* ========== 菜单栏样式 ========== */
QMenuBar {
 background: #1a1a28;
 color: #d0d0d0;
 border-bottom: 1px solid #3d5a80;
 padding: 2px 4px;
 font-size: 9px;
}
QMenuBar::item {
 background: transparent;
 color: #d0d0d0;
 padding: 4px 10px;
 border-radius: 3px;
}
QMenuBar::item:selected {
 background: #3d5a80;
 color: white;
}
QMenuBar::item:pressed {
 background: #5a7ba8;
}

/* ========== 菜单样式 ========== */
QMenu {
 background: #1e1e2e;
 color: #d0d0d0;
 border: 1px solid #3d5a80;
 border-radius: 4px;
 padding: 4px 0px;
}
QMenu::item {
 background: transparent;
 color: #d0d0d0;
 padding: 6px 25px 6px 20px;
 border-radius: 0px;
}
QMenu::item:selected {
 background: #3d5a80;
 color: white;
}
QMenu::item:disabled {
 color: #5a5a6a;
}
QMenu::separator {
 height: 1px;
 background: #3d5a80;
 margin: 4px 10px;
}

/* ========== 消息框样式 ========== */
QMessageBox {
 background: #1e1e2e;
}
QMessageBox QLabel {
 color: #d0d0d0;
 font-family: 'Microsoft YaHei UI', 'Segoe UI', sans-serif;
}
QMessageBox QPushButton {
 background: #2a3a50;
 color: #d0d0d0;
 border: 1px solid #3d5a80;
 border-radius: 4px;
 padding: 6px 20px;
 min-width: 80px;
}
QMessageBox QPushButton:hover {
 background: #3d5a80;
 color: white;
 border: 1px solid #5a9bd5;
}

/* ========== 输入对话框样式 ========== */
QInputDialog {
 background: #1e1e2e;
}
QInputDialog QLabel {
 color: #d0d0d0;
 font-family: 'Microsoft YaHei UI', 'Segoe UI', sans-serif;
 font-size: 10pt;
}
QInputDialog QLineEdit {
 background: #151521;
 color: #98c379;
 border: 1px solid #3d5a80;
 border-radius: 4px;
 padding: 6px 10px;
}
QInputDialog QLineEdit:focus {
 border: 1px solid #5a9bd5;
}
QInputDialog QPushButton {
 background: #2a3a50;
 color: #d0d0d0;
 border: 1px solid #3d5a80;
 border-radius: 4px;
 padding: 6px 20px;
 min-width: 70px;
}
QInputDialog QPushButton:hover {
 background: #3d5a80;
 color: white;
 border: 1px solid #5a9bd5;
}
QInputDialog QPushButton:default {
 background: #3d5a80;
 color: white;
}</string>
